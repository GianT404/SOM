+  val enableBridgelessArchitecture: Boolean = try {
+    com.facebook.react.internal.featureflags.ReactNativeFeatureFlags.enableBridgelessArchitecture()
+  } catch (e: UnsatisfiedLinkError) {
+    false
+  } catch (e: ExceptionInInitializerError) {
+    false
+  }
 }
